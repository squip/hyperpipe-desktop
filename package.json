{
  "name": "hyperpipe-desktop",
  "version": "0.1.12",
  "description": "Desktop client for Hyperpipe peer-to-peer Nostr relays and file sharing",
  "private": true,
  "main": "electron/main.cjs",
  "type": "module",
  "author": "squip",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/squip/hyperpipe.git",
    "directory": "hyperpipe-desktop"
  },
  "homepage": "https://hyperpipe.io",
  "scripts": {
    "dev": "vite --host",
    "dev:web": "vite --host",
    "dev:electron": "node ./scripts/dev-electron.cjs",
    "build:icons": "node ./scripts/generate-icons.mjs",
    "prepare:release-deps": "node ./scripts/prepare-release-deps.cjs",
    "prepare:release-runtime": "node ./scripts/prepare-release-deps.cjs",
    "smoke:worker-runtime": "node ./scripts/smoke-worker-runtime.cjs",
    "build": "tsc -b && vite build",
    "build:web": "tsc -b && vite build",
    "build:desktop": "npm run build:icons && npm run build:web && npm run prepare:release-runtime && electron-builder --config ./electron-builder.config.cjs",
    "dist:desktop": "npm run build:icons && npm run build:web && npm run prepare:release-runtime && electron-builder --config ./electron-builder.config.cjs --publish=never",
    "electron:dev-shell": "electron .",
    "closed-join-sim": "node ./electron/bin/closed-join-sim.mjs",
    "test:unit": "vitest run",
    "test:electron": "brittle electron/test/*.test.js",
    "test:e2e": "playwright test",
    "test:e2e:plugin-manager": "playwright test e2e/plugin-manager-permission-denied.spec.ts",
    "lint": "eslint .",
    "format": "prettier --write .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@squip/hyperpipe-bridge": "^0.1.2",
    "@squip/hyperpipe-core": "^0.1.2",
    "@squip/hyperpipe-core-host": "^0.1.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@getalby/bitcoin-connect-react": "^3.10.0",
    "@noble/hashes": "^1.6.1",
    "@nostr-dev-kit/ndk": "2.18.1",
    "@nostr/gadgets": "npm:@jsr/nostr__gadgets@0.0.43",
    "@jsr/nostr__tools": "2.17.2",
    "@radix-ui/react-alert-dialog": "^1.1.4",
    "@radix-ui/react-avatar": "^1.1.2",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-hover-card": "^1.1.4",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-popover": "^1.1.4",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "1.2.0",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-separator": "^1.1.1",
    "@radix-ui/react-slider": "^1.3.5",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.2",
    "@radix-ui/react-toast": "^1.2.4",
    "@tailwindcss/typography": "^0.5.16",
    "@tiptap/extension-emoji": "^2.26.1",
    "@tiptap/extension-history": "^2.12.0",
    "@tiptap/extension-image": "^2.27.1",
    "@tiptap/extension-link": "^2.27.1",
    "@tiptap/extension-mention": "^2.12.0",
    "@tiptap/extension-placeholder": "^2.12.0",
    "@tiptap/extension-task-item": "^2.27.1",
    "@tiptap/extension-task-list": "^2.27.1",
    "@tiptap/extension-underline": "^2.27.1",
    "@tiptap/pm": "^2.12.0",
    "@tiptap/react": "^2.12.0",
    "@tiptap/starter-kit": "^2.12.0",
    "@tiptap/suggestion": "^2.12.0",
    "@webbtc/webln-types": "^3.0.0",
    "blossom-client-sdk": "^4.1.0",
    "blurhash": "^2.0.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.0",
    "dataloader": "^2.2.3",
    "dayjs": "^1.11.13",
    "debounce": "^3.0.0",
    "embla-carousel-react": "^8.6.0",
    "embla-carousel-wheel-gestures": "^8.1.0",
    "emoji-picker-react": "^4.12.2",
    "flexsearch": "^0.7.43",
    "franc-min": "^6.2.0",
    "i18next": "^24.2.0",
    "i18next-browser-languagedetector": "^8.0.4",
    "jotai": "^2.15.0",
    "lru-cache": "^11.0.2",
    "lucide-react": "^0.469.0",
    "next-themes": "^0.4.6",
    "nostr-wasm": "^0.1.0",
    "nstart-modal": "^2.0.0",
    "path-to-regexp": "^8.2.0",
    "qr-code-styling": "^1.9.2",
    "qr-scanner": "^1.4.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^15.2.0",
    "react-markdown": "^10.1.0",
    "react-markdown-editor-lite": "^1.3.4",
    "react-simple-pull-to-refresh": "^1.3.3",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.5",
    "tailwind-merge": "^2.5.5",
    "tailwindcss-animate": "^1.0.7",
    "tippy.js": "^6.3.7",
    "tiptap-markdown": "^0.8.10",
    "vaul": "^1.1.2",
    "hypercore-crypto": "^3.6.0",
    "yet-another-react-lightbox": "^3.21.7",
    "zod": "^3.24.1"
  },
  "overrides": {
    "@jsr/nostr__tools": "2.17.2",
    "workbox-build": "7.3.0",
    "lodash": "4.17.21"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "brittle": "^3.0.0",
    "electron": "^27.0.0",
    "electron-builder": "^24.6.4",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "fake-indexeddb": "^6.2.5",
    "globals": "^15.13.0",
    "jsdom": "^27.0.1",
    "postcss": "^8.4.49",
    "png-to-ico": "^2.1.8",
    "prettier": "3.4.2",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.18.1",
    "vite": "^6.0.3",
    "vite-plugin-pwa": "0.21.2",
    "vitest": "^3.2.4",
    "workbox-build": "7.3.0",
    "workbox-window": "7.3.0"
  },
  "build": {
    "appId": "com.hyperpipe.desktop",
    "productName": "Hyperpipe",
    "asar": true,
    "asarUnpack": [
      "electron/plugin-runner.cjs"
    ],
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": ".release-runtime",
        "to": "runtime",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "build/icon.icns"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "build/icons"
    }
  }
}
